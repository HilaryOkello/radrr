# ── Filecoin FVM (primary blockchain) ──────────────────────────────────────────
# Deploy contracts: cd contracts/filecoin && npx hardhat run deploy.ts --network filecoin_calibration
# Explorer: https://calibration.filfox.info/en
# Faucet (tFIL): https://faucet.calibration.fildev.network/
FILECOIN_CONTRACT_ADDRESS=0x...
FILECOIN_AGENT_REGISTRY_ADDRESS=0x...
FILECOIN_AGENT_ADDRESS=0x...
FILECOIN_AGENT_PRIVATE_KEY=0x...
# Multicall3 deployed on Calibration (canonical 0xcA11... not available on this network)
FILECOIN_MULTICALL3_ADDRESS=0x519Bc263133Beee1f4CacCCb4f2EB60503177AcD
FILECOIN_RPC_URL=https://api.calibration.node.glif.io/rpc/v1
FILECOIN_CHAIN_ID=314159
# Public (exposed to browser)
NEXT_PUBLIC_FILECOIN_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_FILECOIN_CHAIN_ID=314159

# ── EVM deployer wallet ─────────────────────────────────────────────────────────
# Export from MetaMask: Account → ... → Account Details → Export Private Key
# Fund with tFIL: https://faucet.calibration.fildev.network/
EVM_PLATFORM_PRIVATE_KEY=0x...

# ── Storacha / Filecoin ─────────────────────────────────────────────────────────
# 1. npm install -g @web3-storage/w3cli
# 2. w3 login <email>
# 3. w3 space create radrr-space
# 4. w3 delegation create <server-did> --can 'store/add' --can 'upload/add' | base64
STORACHA_PROOF=<base64-encoded-CAR>

# ── Hypercerts (@hypercerts-org/sdk) ───────────────────────────────────────────
# Mints ERC-1155 Hypercerts on Optimism Sepolia (test) or Optimism mainnet.
# 1. Create a wallet and fund with Sepolia ETH: https://sepoliafaucet.com/
# 2. Set HYPERCERTS_TESTNET=false and use OPTIMISM_RPC_URL for production.
HYPERCERTS_PRIVATE_KEY=0x...           # wallet that signs mint transactions
HYPERCERTS_TESTNET=true                # true = Optimism Sepolia, false = Optimism mainnet
OPTIMISM_SEPOLIA_RPC_URL=https://sepolia.optimism.io
OPTIMISM_RPC_URL=https://mainnet.optimism.io

# ── Encryption (AES-256-GCM key escrow) ─────────────────────────────────────────
# Master secret for encrypting video keys server-side (32+ bytes recommended)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_SECRET=radrr-demo-secret-key-32bytes!

# ── HuggingFace (SigLIP 2 embeddings) ──────────────────────────────────────────
# Create API key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...
