# ── World Chain (primary blockchain) ───────────────────────────────────────────
# Deploy contracts: cd contracts/worldchain && npx hardhat run deploy.ts --network worldchain_testnet
# Explorer: https://worldchain-sepolia.explorer.alchemy.com
WORLDCHAIN_CONTRACT_ADDRESS=0x...
WORLDCHAIN_AGENT_REGISTRY_ADDRESS=0x...
WORLDCHAIN_AGENT_ADDRESS=0x...
WORLDCHAIN_AGENT_PRIVATE_KEY=0x...
WORLDCHAIN_RPC_URL=https://worldchain-sepolia.g.alchemy.com/public
WORLDCHAIN_CHAIN_ID=4801
# Public (exposed to browser)
NEXT_PUBLIC_WORLDCHAIN_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_WORLDCHAIN_CHAIN_ID=4801

# ── EVM deployer wallet (used for Hypercerts + World Chain deployment) ──────────
# Export private key from MetaMask: Account → ... → Account Details → Export Private Key
# Fund on World Chain Sepolia: https://www.alchemy.com/faucets/world-chain-sepolia
EVM_PLATFORM_PRIVATE_KEY=0x...

# ── Storacha / Filecoin ─────────────────────────────────────────────────────────
# 1. npm install -g @web3-storage/w3cli
# 2. w3 login <email>
# 3. w3 space create radrr-space
# 4. w3 delegation create <server-did> --can 'store/add' --can 'upload/add' | base64
STORACHA_PROOF=<base64-encoded-CAR>

# ── World ID v4 ─────────────────────────────────────────────────────────────────
# Get all values from developer.world.org → create app → enable World ID 4.0
WORLDID_RP_ID=rp_...
WORLDID_SIGNING_KEY=0x...
WORLDID_ACTION_ID=radrr-witness-verify
# Public (exposed to browser)
NEXT_PUBLIC_WORLDID_APP_ID=app_...
NEXT_PUBLIC_WORLDID_ACTION_ID=radrr-witness-verify
NEXT_PUBLIC_WORLDID_RP_ID=rp_...

# ── Hypercerts (Sepolia testnet) ────────────────────────────────────────────────
# Same EVM_PLATFORM_PRIVATE_KEY used above
# Fund Sepolia wallet: https://cloud.google.com/application/web3/faucet/ethereum/sepolia
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# ── HuggingFace (SigLIP 2 embeddings) ──────────────────────────────────────────
# Create API key at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...
